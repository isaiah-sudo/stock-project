generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  experiencePoints Int      @default(0)
  portfolioPreset  String   @default("standard")
  emailVerifiedAt  DateTime?
  emailVerificationToken String?  @unique
  emailVerificationExpiresAt DateTime?
  lastPortfolioDigestSentAt DateTime?
  createdAt        DateTime @default(now())

  paperAccount     PaperAccount?
  paperPortfolios  PaperPortfolio[]
  achievements     Achievement[]
  portfolioSnapshots PortfolioSnapshot[]
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "FIRST_TRADE", "TEN_PCT_GAIN", etc.
  unlockedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("achievements")
}

model PaperAccount {
  userId      String @id
  cashBalance Float @default(10000)
  linked      Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions    PaperPosition[]
  transactions PaperTransaction[]

  @@map("paper_accounts")
}

model PaperPosition {
  id          String @id @default(cuid())
  userId      String
  symbol      String
  name        String
  quantity    Int
  averageCost Float

  account     PaperAccount @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("paper_positions")
}

model PaperTransaction {
  id         String @id @default(cuid())
  userId     String
  symbol     String
  side       String // "buy" | "sell"
  quantity   Int
  price      Float
  occurredAt DateTime @default(now())

  account    PaperAccount @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("paper_transactions")
}

model PortfolioSnapshot {
  id               String   @id @default(cuid())
  userId           String
  totalMarketValue Float
  timestamp        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp(sort: Desc)])
  @@map("portfolio_snapshots")
}

model PaperPortfolio {
  id        String   @id @default(cuid())
  userId    String
  preset    String
  cashBalance Float  @default(10000)
  linked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions    PaperPositionV2[]
  transactions PaperTransactionV2[]
  snapshots    PortfolioSnapshotV2[]

  @@unique([userId, preset])
  @@map("paper_portfolios")
}

model PaperPositionV2 {
  id           String   @id @default(cuid())
  portfolioId  String
  symbol       String
  name         String
  quantity     Int
  averageCost  Float

  portfolio    PaperPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
  @@map("paper_positions_v2")
}

model PaperTransactionV2 {
  id           String   @id @default(cuid())
  portfolioId  String
  symbol       String
  side         String
  quantity     Int
  price        Float
  occurredAt   DateTime @default(now())

  portfolio    PaperPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("paper_transactions_v2")
}

model PortfolioSnapshotV2 {
  id               String   @id @default(cuid())
  portfolioId      String
  totalMarketValue Float
  timestamp        DateTime @default(now())

  portfolio        PaperPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, timestamp(sort: Desc)])
  @@map("portfolio_snapshots_v2")
}
