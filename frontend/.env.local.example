# App database
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Prisma CLI only if you use a separate direct connection string.
# DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb

# Server-side only. Used by /api/quote and portfolio refresh logic.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Used by the JWT auth flow in Next.js API routes if you keep the existing login approach.
JWT_SECRET=replace-with-a-long-random-secret
